{
  "name": "@limlabs/rex",
  "version": "0.19.1",
  "description": "Rex - Next.js Pages Router reimplemented in Rust",
  "bin": {
    "rex": "bin/rex.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./document": {
      "types": "./dist/document.d.ts",
      "import": "./dist/document.js"
    },
    "./link": {
      "types": "./dist/link.d.ts",
      "import": "./dist/link.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./head": {
      "types": "./dist/head.d.ts",
      "import": "./dist/head.js"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js"
    },
    "./middleware": {
      "types": "./src/middleware.d.ts",
      "import": "../../runtime/server/middleware.js"
    },
    "./actions": {
      "types": "./src/actions.d.ts",
      "import": "../../runtime/server/actions.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@limlabs/rex-darwin-arm64": "0.19.1",
    "@limlabs/rex-darwin-x64": "0.19.1",
    "@limlabs/rex-linux-x64": "0.19.1",
    "@limlabs/rex-linux-arm64": "0.19.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
