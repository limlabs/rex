{
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "rex/*": ["./node_modules/@limlabs/rex/src/*"],
      "@limlabs/rex/server": ["../../packages/rex/src/server.ts"]
    }
  },
  "include": ["pages", "server.ts"]
}
