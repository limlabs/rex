{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "rex/*": ["./node_modules/@limlabs/rex/src/*", "../../node_modules/@limlabs/rex/src/*"]
    }
  },
  "include": ["pages/**/*"]
}
